Notebook[{

Cell[CellGroupData[{
Cell["FFTLog Redshift-Space Matter Master Integrals", "Title",ExpressionUUID->"d75358bb-771c-4f9d-90c3-c3e18ae8eaf0"],

Cell["\<\
This notebook is the redshift-space continuation of the real-space matter \
flow. It first checks the low-order CLASS-PT line-of-sight master integrals \
`A1..C4` against the generic Gamma-function derivation, then validates the \
pure-matter Gaussian redshift-space sector subset against the local \
`pt_matrix/redshift_space/gauss` files.\
\>", "Text",ExpressionUUID->"bbd8469e-73d1-404a-bc78-e6e09941d5e9"],

Cell[CellGroupData[{

Cell["Setup", "Section",ExpressionUUID->"4d2d2f17-d63b-4f39-bcc5-67135b61c09b"],

