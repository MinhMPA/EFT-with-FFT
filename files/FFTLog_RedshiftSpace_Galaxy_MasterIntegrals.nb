Cell[CellGroupData[{

Cell["Notes", "Section",ExpressionUUID->"06c3ebeb-c198-47f7-9297-7360c76f8ce6"],

Cell["\<\
The point of this notebook is not to invent a second derivation route for \
every single sector file. It is to expose the full Gaussian galaxy \
decomposition in one place, keep it on the same analytic footing as the \
simpler notebooks, and check that the exact reduced sector expressions line \
up with the package contract before moving on to the more elaborate Lya case.\
\
\>", "Text",ExpressionUUID->"57bec709-f795-49f9-bc96-59e01b3bea9a"]
}, Open  ]]
}, Open  ]]
