  RowBox[{
   RowBox[{"\<\"pk_lin nu=-0.3\"\>", "\[Rule]", 
    RowBox[{"-", "0.3`"}]}], ",", 
   RowBox[{"\<\"pk_lin nu=-0.7\"\>", "\[Rule]", 
    RowBox[{"-", "0.7`"}]}], ",", 
   RowBox[{"\<\"pk_lin nu=-1.6\"\>", "\[Rule]", 
