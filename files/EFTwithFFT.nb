Cell[CellGroupData[{

Cell["\<\
4. Linear Wiggle-noWiggle Split and Infrared Resummation Ingredients\
\>", "Section",
 CellChangeTimes->{{3.984953316078249*^9, 
  3.984953334423668*^9}},ExpressionUUID->"941c1981-0dd6-47ab-8cc0-\
d515b535bf70"],

Cell["\<\
Build the linear spectrum, split it into no-wiggle and wiggly pieces, and \
compute the anisotropic IR-damping ingredients. This follows the note\
\[CloseCurlyQuote]s separation between the FFTLog reduction and the later IR \
assembly.\
\>", "Text",ExpressionUUID->"52ef4bda-240a-4079-8ed4-66ebfcb1e285"],

Cell["\<\
lin = EFTwithFFT`LoadLinearSpectrum[linearPath];
split = EFTwithFFT`BuildNoWiggleSpectrum[lin, \"h\" -> h];
kPlot = N @ lin[\"k\"];
kPlotRSD = Select[kPlot, # <= 0.3 &];
linNW = <|
  \"Plin\" -> split[\"PnwFunction\"],
  \"Data\" -> split[\"PnwData\"],
  \"kMin\" -> lin[\"kMin\"],
  \"kMax\" -> lin[\"kMax\"],
  \"Path\" -> Lookup[lin, \"Path\", Missing[\"NoPath\"]]
|>;
sigma2 = EFTwithFFT`GetSigma2[split, kS, rBAO];
dSigma2 = EFTwithFFT`GetDeltaSigma2[split, kS, rBAO];
dampAssoc = EFTwithFFT`BuildIRDampingFactor[<|\"f\" -> fGrowth|>, sigma2, \
dSigma2];
splitSummary = <|\"Sigma2\" -> sigma2, \"DeltaSigma2\" -> dSigma2, \"kRange\" \
-> {lin[\"kMin\"], lin[\"kMax\"]}|>;\
\>", "Input",
 CellLabel->
  "(Debug) In[991]:=",ExpressionUUID->"cf0f638f-e719-4151-8ce5-8636bfa3d9a8"],

Cell[CellGroupData[{

Cell["splitSummary", "Input",
 CellLabel->
  "(Debug) In[1000]:=",ExpressionUUID->"8c18b74b-55db-40f0-9b7d-4f5955bd7197"],

Cell[BoxData[
 RowBox[{"\[LeftAssociation]", 
  RowBox[{
   RowBox[{"\<\"Sigma2\"\>", "\[Rule]", "15.029955680088623`"}], ",", 
   RowBox[{"\<\"DeltaSigma2\"\>", "\[Rule]", "4.237205862050391`"}], ",", 
   RowBox[{"\<\"kRange\"\>", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"9.954008287621754`*^-6", ",", "10046.204213467894`"}], 
     "}"}]}]}], "\[RightAssociation]"}]], "Output",
 CellChangeTimes->{3.98495373107788*^9},
 CellLabel->
  "(Debug) Out[1000]=",ExpressionUUID->"eb46af50-b911-48a6-af54-b69bd0210a32"]
}, Open  ]]
}, Open  ]],

